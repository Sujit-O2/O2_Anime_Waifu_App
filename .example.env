# O2-WAIFU Environment Configuration
# Copy this file to .env and fill in your API keys

# Groq API - Used for LLM reasoning, STT (Whisper), and TTS (Orpheus)
GROQ_API_KEY=your_groq_api_key_here

# Picovoice - Used for wake word detection (Porcupine engine)
PICOVOICE_API_KEY=your_picovoice_api_key_here

# Cloudinary - Used for video CDN and asset pipeline
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Mailjet - Used for sending emails via voice commands
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key

# OpenWeatherMap - Used for weather queries
OPENWEATHER_API_KEY=your_openweather_api_key

# Gemini API - Used for PresenceMessageGenerator (alternative to OpenAI)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI API - Used for PresenceMessageGenerator (alternative to Gemini)
OPENAI_API_KEY=your_openai_api_key
