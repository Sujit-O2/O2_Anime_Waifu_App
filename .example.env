# List of Groq API keys for LLM, TTS, and fallback STT (Comma separated)
API_KEY="gsk_FAKE_KEY_01,gsk_FAKE_KEY_02,gsk_FAKE_KEY_03"

# --- LIVE STREAMING STT (GLADIA) ---
# List of Gladia API keys for real-time STT (Comma separated) from app.gladia.io
GladiaSTT="YOUR_GLADIA_KEY_01,YOUR_GLADIA_KEY_02"

# --- VOICE WAKE WORD (PICOVOICE) ---
# Your Picovoice Access Key from https://console.picovoice.ai/
WAKE_WORD_KEY="YOUR_PICOVOICE_ACCESS_KEY_HERE"

# --- EMAIL SERVICE (BREVO) ---
# API Key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY="xkeysib-YOUR_BREVO_API_KEY_HERE"
# Verified sender email — must be added at https://app.brevo.com/senders/list
SENDER_EMAIL="your_verified_sender@example.com"

# --- VIDEO CONTENT (CLOUDINARY) ---
# Credentials from https://cloudinary.com/
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_VIDEO_FOLDER="your_video_folder"

# --- WEATHER SERVICE ---
# API Key from https://openweathermap.org/
OPENWEATHER_API_KEY="your_weather_api_key"

# --- AI MUSIC + VIDEO GENERATION (6-provider fallback chain) ---
# Provider 1: deAPI.ai (AceStep music + LTX-2.3 video) — FREE $5 signup, NO card
# Signup: https://deapi.ai/register
DEAPI_API_KEY="deapi_key1,deapi_key2"
# Provider 2: Replicate (MusicGen + zeroscope-v2-xl) — FREE ~$2-5 credits
# Signup: https://replicate.com/account/api-tokens
REPLICATE_API_KEY="r8_key1,r8_key2"
# Provider 3: FAL.ai (fast-svd-lcm video) — FREE 10k GPU sec/month
# Signup: https://fal.ai/dashboard/keys
FAL_API_KEY="fal_key1,fal_key2"
# Provider 4: Stability AI (stable-video-diffusion) — FREE 25 gen/month
# Signup: https://platform.stability.ai/account/keys
STABILITY_API_KEY="sk-key1,sk-key2"
# Provider 5: RunwayML Gen-3 (video) — FREE $2.50 credits
# Signup: https://app.runwayml.com/account/api-keys
RUNWAY_API_KEY="rw_key1,rw_key2"
# Provider 6: HuggingFace (musicgen-small + damo-vilab video) — FREE, works without key
# Signup: https://huggingface.co/settings/tokens
HF_API_KEY="hf_key1,hf_key2"
