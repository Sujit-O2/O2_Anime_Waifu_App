# --- AI & GROQ CONFIGURATION ---
# List of Groq API keys for LLM (Comma separated)
API_KEY="gsk_FAKE_KEY_01,gsk_FAKE_KEY_02,gsk_FAKE_KEY_03"

# Dedicated Groq Key for Voice STT (Whisper)
GROQ_API_KEY_VOICE="gsk_FAKE_VOICE_KEY_01"

# --- VOICE WAKE WORD (PICOVOICE) ---
# Your Picovoice Access Key from https://console.picovoice.ai/
WAKE_WORD_KEY="YOUR_PICOVOICE_ACCESS_KEY_HERE"

# --- EMAIL SERVICE (MAILJET) ---
# API Key and Secret from https://www.mailjet.com/
MAIL_JET_API="FAKE_MAILJET_API_KEY"
MAILJET_SEC="FAKE_MAILJET_SECRET"

# --- VIDEO CONTENT (CLOUDINARY) ---
# Credentials from https://cloudinary.com/
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_VIDEO_FOLDER="your_video_folder"

# --- WEATHER SERVICE ---
# API Key from https://openweathermap.org/
OPENWEATHER_API_KEY="your_weather_api_key"
