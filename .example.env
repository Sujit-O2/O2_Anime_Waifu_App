# List of Groq API keys for LLM, TTS, and fallback STT (Comma separated)
API_KEY="gsk_FAKE_KEY_01,gsk_FAKE_KEY_02,gsk_FAKE_KEY_03"

# --- LIVE STREAMING STT (GLADIA) ---
# List of Gladia API keys for real-time STT (Comma separated) from app.gladia.io
GladiaSTT="YOUR_GLADIA_KEY_01,YOUR_GLADIA_KEY_02"

# --- VOICE WAKE WORD (PICOVOICE) ---
# Your Picovoice Access Key from https://console.picovoice.ai/
WAKE_WORD_KEY="YOUR_PICOVOICE_ACCESS_KEY_HERE"

# --- EMAIL SERVICE (BREVO) ---
# API Key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY="xkeysib-YOUR_BREVO_API_KEY_HERE"
# Verified sender email — must be added at https://app.brevo.com/senders/list
SENDER_EMAIL="your_verified_sender@example.com"

# --- VIDEO CONTENT (CLOUDINARY) ---
# Credentials from https://cloudinary.com/
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
