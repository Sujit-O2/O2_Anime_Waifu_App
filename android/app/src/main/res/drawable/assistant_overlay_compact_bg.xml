<?xml version="1.0" encoding="utf-8"?>
<!-- Main sheet background: deep dark glassmorphism with gradient + red accent border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle top gradient shimmer (Red to Transparent) -->
    <item>
        <shape>
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#33FF3D5A"
                android:endColor="#00FF3D5A" />
        </shape>
    </item>
    <!-- Main translucent layer (Allows GIF to shine through while keeping text readable) -->
    <item>
        <shape>
            <corners
                android:topLeftRadius="28dp"
                android:topRightRadius="28dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <solid android:color="#770D1018" />
            <stroke
                android:width="1.5dp"
                android:color="#80FF3D5A" />
        </shape>
    </item>
</layer-list>
