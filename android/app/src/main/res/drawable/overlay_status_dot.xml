<?xml version="1.0" encoding="utf-8"?>
<!-- Pulsing status indicator dot (red glow) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#33FF3D5A" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#FFFF3D5A" />
        </shape>
    </item>
</layer-list>
