<?xml version="1.0" encoding="utf-8"?>
<!-- User chat bubble background: red/pink gradient with rounded corners -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <corners android:radius="16dp" />
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#E6FF3D5A"
        android:endColor="#E6CC0030" />
    <stroke
        android:width="1dp"
        android:color="#40FFFFFF" />
</shape>
