<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/assistantOverlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <!-- Dim scrim -->
    <View
        android:id="@+id/overlayScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#99000000" />

    <!-- Bottom sheet -->
    <LinearLayout
        android:id="@+id/assistantOverlaySheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/overlay_glass_bg"
        android:paddingStart="16dp"
        android:paddingTop="0dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="24dp">

        <!-- Drag handle -->
        <FrameLayout
            android:id="@+id/overlayDragHandle"
            android:layout_width="match_parent"
            android:layout_height="28dp">
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="@drawable/overlay_handle_premium" />
        </FrameLayout>

        <!-- Header: avatar + name + dot + close -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Avatar -->
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginEnd="12dp"
                android:src="@mipmap/ic_launcher"
                android:scaleType="centerCrop"
                android:background="@drawable/overlay_status_dot_modern" />

            <!-- Name + subtitle -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/overlayStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zero Two"
                    android:textColor="#FFFFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Swipe down to close"
                    android:textColor="#55FFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Status dot -->
            <View
                android:id="@+id/overlayStatusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/overlay_status_dot_modern" />

            <!-- Hidden close button (kept for code compatibility) -->
            <ImageButton
                android:id="@+id/overlayCloseButton"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone"
                android:contentDescription="Close" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#33FF0057"
            android:layout_marginBottom="12dp" />

        <!-- Chat transcript -->
        <ScrollView
            android:id="@+id/overlayTranscriptScroll"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="12dp"
            android:scrollbars="none"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/overlayChatList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </ScrollView>

        <!-- Waveform row (hidden by default) -->
        <LinearLayout
            android:id="@+id/overlayWaveformRow"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:background="@drawable/overlay_wave_bg">

            <View android:layout_width="3dp" android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/overlay_wave_bar_animated" />
            <View android:layout_width="3dp" android:layout_height="18dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/overlay_wave_bar_animated" />
            <View android:layout_width="3dp" android:layout_height="12dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/overlay_wave_bar_animated" />
            <View android:layout_width="3dp" android:layout_height="22dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/overlay_wave_bar_animated" />
            <View android:layout_width="3dp" android:layout_height="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/overlay_wave_bar_animated" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤  Listening..."
                android:textColor="#FFFF4FA8"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Mic -->
            <ImageButton
                android:id="@+id/overlayMicButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/overlay_mic_btn_modern"
                android:contentDescription="Voice"
                android:padding="12dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="#FFFFFFFF" />

            <!-- Text input -->
            <EditText
                android:id="@+id/overlayInput"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/overlay_input_modern"
                android:hint="Ask Zero Two anything..."
                android:imeOptions="actionSend"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#66FFFFFF"
                android:textSize="14sp" />

            <!-- Send -->
            <ImageButton
                android:id="@+id/overlaySendButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/overlay_send_btn_modern"
                android:contentDescription="Send"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#FFFFFFFF" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
