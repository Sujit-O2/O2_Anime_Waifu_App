<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0A12">

    <!-- Zero Two Background Image -->
    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/zt_bg"
        android:scaleType="centerCrop"
        android:alpha="0.65" />

    <!-- Pink gradient left overlay (for text readability) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_gradient_overlay" />

    <!-- Content at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_affection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Her Darling 🌸"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="6" />

        <TextView
            android:id="@+id/tv_latest_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to talk to me, Darling~"
            android:textColor="#EEDDFF"
            android:textSize="12sp"
            android:ellipsize="end"
            android:maxLines="2"
            android:layout_marginTop="2dp"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btn_chat"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:background="#CCFF4081"
                android:text="💬 Chat"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btn_voice"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="36dp"
                android:background="#CC9C27B0"
                android:text="🎙 Voice"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
