<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/widget_waifu_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_stat_waifu" 
        app:tint="#FF4081" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_affection_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stranger"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_affection_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="0 pts"
            android:textColor="#BDBDBD"
            android:textSize="14sp" />
            
        <ProgressBar
            android:id="@+id/widget_affection_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#FF4081" />

    </LinearLayout>

</LinearLayout>
