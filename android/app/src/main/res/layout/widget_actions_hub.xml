<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#100016">

    <!-- Zero Two Background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/zt_bg"
        android:scaleType="centerCrop"
        android:alpha="0.50" />

    <!-- Dark overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0A0014" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_morning"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:layout_margin="3dp"
            android:background="#CCFF4081"
            android:text="🌅 Morning"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"/>

        <Button
            android:id="@+id/btn_sleep"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:layout_margin="3dp"
            android:background="#CC311B92"
            android:text="🌙 Sleep"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"/>

        <Button
            android:id="@+id/btn_pomodoro"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:layout_margin="3dp"
            android:background="#CC880E4F"
            android:text="🍅 Focus"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"/>

        <Button
            android:id="@+id/btn_chat"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:layout_margin="3dp"
            android:background="#CC4A148C"
            android:text="💬 Chat"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>
</RelativeLayout>
