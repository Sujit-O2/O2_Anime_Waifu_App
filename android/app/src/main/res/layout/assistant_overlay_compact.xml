<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/assistantOverlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <!-- Transparent scrim behind the sheet -->
    <View
        android:id="@+id/overlayScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#00000000" />

    <!-- Main bottom sheet -->
    <FrameLayout
        android:id="@+id/assistantOverlaySheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/assistant_overlay_compact_bg"
        android:clipToOutline="true">

        <!-- Background animated GIF -->
        <pl.droidsonroids.gif.GifImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/sidebar_bg" />

        <!-- Content layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/assistant_overlay_compact_bg"
            android:paddingStart="20dp"
            android:paddingTop="0dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp"
            android:clickable="true"
            android:focusable="true">

        <!-- Handle bar with expanded touch target for resizing -->
        <FrameLayout
            android:id="@+id/overlayDragHandle"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp">
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="@drawable/overlay_handle_bar" />
        </FrameLayout>

        <!-- Header row: avatar dot + title + close -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Animated status dot -->
            <View
                android:id="@+id/overlayStatusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="9dp"
                android:background="@drawable/overlay_status_dot" />

            <!-- Name / status text -->
            <TextView
                android:id="@+id/overlayStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="002"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Close button (hidden per user request) -->
            <ImageButton
                android:id="@+id/overlayCloseButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:visibility="gone"
                android:background="@drawable/overlay_icon_btn_bg"
                android:contentDescription="Close"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#AAFFFFFF" />
        </LinearLayout>

        <!-- Transcript / response bubble array (now holds actual layout bubbles) -->
        <ScrollView
            android:id="@+id/overlayTranscriptScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="140dp"
            android:layout_marginBottom="14dp"
            android:scrollbars="none"
            android:fillViewport="true">
            
            <LinearLayout
                android:id="@+id/overlayChatList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />
        </ScrollView>

        <!-- Waveform / listening pulse row -->
        <LinearLayout
            android:id="@+id/overlayWaveformRow"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginBottom="14dp"
            android:gravity="center_vertical|start"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- Five animated bars (set visibility=visible when listening) -->
            <View android:layout_width="4dp" android:layout_height="12dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/overlay_wave_bar" />
            <View android:layout_width="4dp" android:layout_height="20dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/overlay_wave_bar" />
            <View android:layout_width="4dp" android:layout_height="9dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/overlay_wave_bar" />
            <View android:layout_width="4dp" android:layout_height="22dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/overlay_wave_bar" />
            <View android:layout_width="4dp" android:layout_height="14dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/overlay_wave_bar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Listening..."
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Action row: mic + input + send -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Mic button with glow bg -->
            <ImageButton
                android:id="@+id/overlayMicButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/overlay_mic_btn_bg"
                android:contentDescription="Voice command"
                android:padding="12dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="#FFFF5252" />

            <!-- Text input field -->
            <EditText
                android:id="@+id/overlayInput"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/overlay_input_field_bg"
                android:hint="Type a command..."
                android:imeOptions="actionSend"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#66FFFFFF"
                android:textSize="14sp" />

            <!-- Send button -->
            <ImageButton
                android:id="@+id/overlaySendButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_send_btn_bg"
                android:contentDescription="Send command"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#FFFFFFFF" />
        </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</FrameLayout>
