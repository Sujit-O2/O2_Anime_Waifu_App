org.gradle.jvmargs=-Xmx12g -XX:MaxMetaspaceSize=2g -XX:ReservedCodeCacheSize=1g -XX:+UseG1GC -XX:InitiatingHeapOccupancyPercent=75
org.gradle.daemon=false
org.gradle.parallel=false
org.gradle.workers.max=1
org.gradle.configureondemand=false
android.useAndroidX=true

# Opt out of new DSL - Flutter Gradle plugin does not yet support it
android.newDsl=false


# Kotlin incremental compilation (stable with Kotlin 2.2.20+)
kotlin.incremental=true
kotlin.caching.enabled=true

# Run Kotlin compiler out-of-process
kotlin.compiler.execution.strategy=out-of-process

# Build settings
org.gradle.parallel=false
org.gradle.caching=true
org.gradle.configureondemand=true
org.gradle.workers.max=2
org.gradle.daemon.idletimeout=120000

# Faster R class generation
android.nonTransitiveRClass=true
org.gradle.jvmargs=-Xmx6g -XX:MaxMetaspaceSize=1g -Dorg.gradle.daemon=false
org.gradle.parallel=false
org.gradle.workers.max=2
