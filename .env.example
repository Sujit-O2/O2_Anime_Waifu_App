# O2-WAIFU Configuration Template
# Copy this file to .env and fill in your actual API keys

# Groq API (LLM, STT, TTS)
GROQ_API_KEY=your_groq_api_key_here

# Alternative LLM Providers (optional)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
KIMI_API_KEY=your_kimi_api_key_here

# Cloudinary (Image/Video CDN)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here

# Brevo (Email Service - replaces Mailjet)
BREVO_API_KEY=your_brevo_api_key_here

# Email Configuration
EMAIL_FROM_ADDRESS=your_email@example.com
EMAIL_FROM_NAME=O2-WAIFU

# OpenWeather API
WEATHER_API_KEY=your_openweather_api_key_here

# Google Drive (Backup)
GOOGLE_DRIVE_CLIENT_ID=your_google_drive_client_id_here
GOOGLE_DRIVE_CLIENT_SECRET=your_google_drive_client_secret_here

# Gladia (Streaming STT - Optional)
GLADIA_API_KEY=your_gladia_api_key_here

# Firebase Configuration (Optional)
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_DATABASE_URL=your_firebase_database_url_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here
