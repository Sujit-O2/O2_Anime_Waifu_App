# API Keys - Replace with your actual keys
# Get Groq API keys from: https://console.groq.com/keys
# You can add multiple keys separated by commas for rotation
API_KEY="YOUR_GROQ_API_KEY_1,YOUR_GROQ_API_KEY_2,YOUR_GROQ_API_KEY_3"

# Optional: Override the Groq API base URL (default: https://api.groq.com/openai/v1/chat/completions)
# GROQ_API_BASE_URL="https://api.groq.com/openai/v1/chat/completions"

# Email Service (Brevo/Sendinblue)
# Get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY="YOUR_BREVO_API_KEY"

# Cloudinary (for video/image hosting)
# Get from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME"
CLOUDINARY_API_KEY="YOUR_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET"
CLOUDINARY_VIDEO_FOLDER="o2"

# Weather Service
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY="YOUR_OPENWEATHER_API_KEY"

# Speech-to-Text (Gladia)
# Get from: https://www.gladia.io/
# Multiple keys for rotation
GladiaSTT="YOUR_GLADIA_KEY_1,YOUR_GLADIA_KEY_2,YOUR_GLADIA_KEY_3"
